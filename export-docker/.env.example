# KAI-Flow Docker Environment Configuration
# Copy this file to .env and customize

# Database
POSTGRES_USER=kaiflow
POSTGRES_PASSWORD=kaiflow_secret
POSTGRES_DB=kaiflow
DATABASE_URL=postgresql://kaiflow:kaiflow_secret@postgres:5432/kaiflow

# Security (CHANGE THESE IN PRODUCTION!)
SECRET_KEY=your-secret-key-change-in-production
CREDENTIAL_MASTER_KEY=your-credential-key-change-in-production

# Optional: Master API Key for backend-to-backend calls
# MASTER_API_KEY=your-master-api-key

# Frontend
VITE_API_BASE_URL=http://localhost:8000
